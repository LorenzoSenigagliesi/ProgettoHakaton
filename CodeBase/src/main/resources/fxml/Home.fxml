<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="unicam.controller.HomeController"
            styleClass="root">

    <!-- Top Header -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 40 10 40;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="HackHub" style="-fx-text-fill: #6366F1; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
                <HBox fx:id="headerActions" spacing="10" alignment="CENTER_RIGHT"/>
            </HBox>

            <!-- User Info Bar -->
            <HBox fx:id="userInfoBar" alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 8 40; -fx-background-color: #1E1E2E;"
                  managed="false" visible="false">
            </HBox>

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 40 20 40;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Hackathon Disponibili" styleClass="title-label"/>
                    <Label fx:id="lblUserInfo" text="Consultazione elenco hackathon" styleClass="subtitle-label"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- Center: Hackathon List -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox fx:id="hackathonList" spacing="16" style="-fx-padding: 10 40 30 40;">
                <!-- Cards generate dinamicamente dal controller -->
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
