<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="unicam.controller.MentoreController"
            styleClass="root">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar"
              style="-fx-padding: 16 40;">
            <Button text="Indietro" styleClass="btn-secondary" onAction="#onIndietro"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblTitolo" text="Dashboard Mentore" styleClass="title-label"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24" style="-fx-padding: 24 40 40 40;">

                <!-- Feedback -->
                <Label fx:id="lblFeedback" text="" managed="false" visible="false"
                       style="-fx-font-size: 14px;"/>

                <!-- Richieste di Supporto -->
                <VBox spacing="12" styleClass="detail-card">
                    <Label text="Richieste di Supporto" styleClass="text-primary"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox fx:id="richiesteList" spacing="8"/>
                </VBox>

                <!-- Call Programmate -->
                <VBox spacing="12" styleClass="detail-card">
                    <Label text="Call Programmate" styleClass="text-primary"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox fx:id="callList" spacing="8"/>
                </VBox>

                <!-- Proponi Nuova Call -->
                <VBox spacing="12" styleClass="detail-card">
                    <Label text="Proponi Nuova Call" styleClass="text-primary"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <Label text="Hackathon" styleClass="text-secondary"/>
                    <ComboBox fx:id="cmbHackathon" styleClass="combo-box-dark"
                              maxWidth="Infinity" promptText="Seleziona hackathon"/>

                    <Label text="Team" styleClass="text-secondary"/>
                    <ComboBox fx:id="cmbTeam" styleClass="combo-box-dark"
                              maxWidth="Infinity" promptText="Seleziona team"/>

                    <Label text="Titolo Call" styleClass="text-secondary"/>
                    <TextField fx:id="txtCallTitolo" promptText="Titolo della call"
                               styleClass="text-field-dark"/>

                    <Label text="Descrizione" styleClass="text-secondary"/>
                    <TextArea fx:id="txtCallDescrizione" promptText="Descrizione opzionale..."
                              prefHeight="80" wrapText="true" styleClass="text-area-dark"/>

                    <Label text="Data" styleClass="text-secondary"/>
                    <DatePicker fx:id="dpCallData" styleClass="combo-box-dark"
                                maxWidth="Infinity"/>

                    <Label text="Luogo / Link" styleClass="text-secondary"/>
                    <TextField fx:id="txtCallLuogo" promptText="Luogo o link della call"
                               styleClass="text-field-dark"/>

                    <Button text="Proponi Call" styleClass="btn-accent" onAction="#onProponiCall"
                            maxWidth="Infinity" style="-fx-padding: 12;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
